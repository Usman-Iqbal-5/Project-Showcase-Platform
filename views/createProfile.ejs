          <img src="/images/template1.png" alt="image of the first template">
        </label>
        <label class="template">
          <input id="template2" type="radio" name="template" value="2" <%= experience.template_value== 2? "checked" : "" %>>
          <img src="images/template2.png" alt="image of the second template">
        </label>
      </div>

      <h5>Skills:</h5>
      <div id="outerExperienceContainer">
        <% experience.tags.forEach((tag, index)=> { %>
        <div id="innerExperienceContainer<%= tag.tag_id%>">
          <div class="skillExperienceFlexBox">
            <input type="hidden" name="skills[<%= index %>][id]" value="<%= tag.tag_id %>">
            <input class="editExperienceSkill" type="text" name="skills[<%= index %>][name]" value="<%= tag.tag_name %>">
            <button class="deleteExperienceTagButton" data-id="<%= tag.tag_id %>">
              <svg class="trashCan" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640">
                <!--!Font Awesome Free v7.0.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2025 Fonticons, Inc.-->
                <path d="M262.2 48C248.9 48 236.9 56.3 232.2 68.8L216 112L120 112C106.7 112 96 122.7 96 136C96 149.3 106.7 160 120 160L520 160C533.3 160 544 149.3 544 136C544 122.7 533.3 112 520 112L424 112L407.8 68.8C403.1 56.3 391.2 48 377.8 48L262.2 48zM128 208L128 512C128 547.3 156.7 576 192 576L448 576C483.3 576 512 547.3 512 512L512 208L464 208L464 512C464 520.8 456.8 528 448 528L192 528C183.2 528 176 520.8 176 512L176 208L128 208zM288 280C288 266.7 277.3 256 264 256C250.7 256 240 266.7 240 280L240 456C240 469.3 250.7 480 264 480C277.3 480 288 469.3 288 456L288 280zM400 280C400 266.7 389.3 256 376 256C362.7 256 352 266.7 352 280L352 456C352 469.3 362.7 480 376 480C389.3 480 400 469.3 400 456L400 280z" />
              </svg>
            </button>
          </div>
        </div>
        <% }) %>
      </div>
      <button class="addNewExperienceSkills" type="button">Add
        Skills</button>
      <div class="saveUpdatedExperienceContainer">
        <button class="saveUpdatedExperience" type="submit">Save</button>
      </div>

