      <% }) %>

      <div>
        <h5>Template chosen:</h5>
        <img id="templateView" src="<%= experience.template_value == 1 ? '/images/template1.png' : '/images/template2.png' %>" alt="Template preview">
      </div>

      <h5>Skills</h5>
      <% experience.tags.forEach((tag)=> { %>
      <p class="skillsViewParagraph">
        <%= tag.tag_name %>
      </p>
      <% }) %>

      <div class="ViewButtonsContainer">
        <button class="edit-experience-button" data-id="<%= experience.experience_id %>">Edit
          experience</button>
        <button class="delete-experience-button" data-id="<%= experience.experience_id %>" data-name="<%= experience.experience_name %>">Delete
          experience</button>

      </div>
    </div>

    <form id="experienceEditForm<%= experience.experience_id %>" action="/saveExperience" method="post" <%=openForm==experience.experience_id.toString() ? '' : 'hidden' %>>
      <h3>Edit Experience</h3>
      <input type="hidden" name="experience_id" value="<%= experience.experience_id %>">
      <label for="title">experience Title</label>
      <input class="experience-title" type="text" name="title" value="<%=experience.experience_name %>">
      <label for="experience-edit-form-description">experience Description</label>
      <textarea name="description" id="experience-edit-form-description" class="experience-description" placeholder="Enter experience description"> <%= experience.description %></textarea>
      <label for="experience-edit-form-explanation">Job Explanation</label>
      <textarea name="explanation" id="experience-edit-form-explanation" class="project-explanation" placeholder="Enter "> <%= experience.job_explanation %></textarea>

      <% experience.images.forEach((image)=>{ %>
      <img src="<%= image.secure_url %>" alt="experience image" width="100px">
      <p>
        <%= image.original_filename %>
      </p>
      <% }) %>

      <button type="button" class="editExperienceImagesButton" data-id="<%= experience.experience_id %>">Edit
