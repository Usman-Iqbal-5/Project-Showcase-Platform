    <% }) %>

    <form id="addExperienceEntryForm" action="/addExperience" method="post" autocomplete="off" enctype="multipart/form-data">
      <h3>Upload a New Experience</h3>
      <label for="experience-title" class="entry-form-title">Experience Title</label>
      <input class="experience-title" type="text" name="title" id="experience-title" placeholder="Enter Experience Title" required>
      <label for="experience-initial-description" class="entry-form-title">Experience Description</label>
      <textarea class="experience-description" name="description" id="experience-initial-description" placeholder="Enter experience description"></textarea>
      <label for="experience-initial-explantion" class="entry-form-title">Experience Job Explanation</label>
      <textarea class="experience-explanation" name="explanation" id="experience-initial-explanation" placeholder="Enter how this experience links to your intended job role"></textarea>

      <label class="entry-form-title">Uplaod Experience Media</label>
      <label for="experienceImages" class="custom-file-upload">Uplaod images</label>
      <input type="file" name="experienceImages" id="experienceImages" accept=".jpg, .jpeg, .png, .webp" multiple>
      <span class="experienceFileView" id="experienceImagesFileName">No files chosen</span>

      <label for="experienceVideos" class="custom-file-upload">Uplaod videos</label>
      <input type="file" name="experienceVideos" id="experienceVideos" accept=".mp4, .mov, .avi, .webm" multiple>
      <span class="experienceFileView" id="experienceVideosFileName">No files chosen</span>

      <label for="experienceDocs" class="custom-file-upload">Uplaod Files</label>
      <input type="file" name="experienceDocs" id="experienceDocs" accept=".doc,.docx,.txt" multiple>
      <span class="experienceFileView" id="experienceDocsFileName">No files chosen</span>

      <div class="templateContainer">
        <label class="template-title">Choose a project template:</label>
        <label class="template">
          <input id="template1" type="radio" name="template" value="1" checked>
          <img src="/images/template1.png" alt="image of the first template">
        </label>
        <label class="template">
          <input id="template2" type="radio" name="template" value="2">
          <img src="images/template2.png" alt="image of the second template">
        </label>
      </div>

      <div id="experienceskillsContainer">
        <label for="experienceSkills" class="entry-form-title">Skills</label>
        <input class="experiences-skill-field" type="text" name="experienceSkills[]" placeholder="Add a skill" id="experienceSkills">
      </div>
      <button id="addExperienceSkillButton" type="button">Add skill</button>
      <button id="add-experience" type="submit">Add New Experience</button>
    </form>

 
<!--Destructive actions -->
    
 <h2>Destructive Actions</h2>

<div class="delete-account-container">
  <!-- Delete Account Button -->
   <h3 id="delete-title">Delete Account</h3>
  <button id="deleteAccountButton" class="danger-delete-button">
    Delete My Account
  </button>
</div>

<!-- DELETE PROJECT/EXPERIENCE CONFIRMATION MODAL -->
<div id="deleteModalOverlay" class="modal-hidden modal-overlay">
  <div id="deleteModal" class="modal-box">
    <h3 id="warning" class="warning">Remove item</h3>
    <div class="underline"></div>
    <p id="modal-text"></p>
    <button id="confirmDelete" class="danger-button">Delete</button>
    <button id="cancelDelete" class="cancel-button">Cancel</button>
  </div>
</div>

<!-- DELETE ACCOUNT CONFIRMATION MODAL -->
<div id="deleteAccountModalOverlay" class="modal-hidden modal-overlay">
  <div id="deleteAccountModal" class="modal-box">
    <h3 id="delete-title" class="warning">Delete Account</h3>
    <div class="underline"></div>
    <p id="deleteAccountText">Are you sure you want to delete your account? This cannot be undone.</p>
    <button id="confirmDeleteAccount" class="danger-button">Delete</button>
    <button id="cancelDeleteAccount" class="cancel-button">Cancel</button>
  </div>
</div>

  </main>
  <%- include("partials/footer.ejs") %>


  <script src="/library/vanilla-toast/vanilla-toast.js"></script>
  <script src="js/experience.js"></script>
  <script src="js/projects.js"></script>
  <script src="js/profileDetails.js"></script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    <% if (toast) { %>
      vanillaToast.<%= toast.type %>("<%= toast.message %>", {
        timeout: 3000,
        position: "bottom center"
      });
    <% } %>
  });
</script>

<script>
// ACCOUNT DELETION JS
document.getElementById("deleteAccountButton").addEventListener("click", () => {
  document.getElementById("deleteAccountModalOverlay").classList.remove("modal-hidden");
});

document.getElementById("cancelDeleteAccount").addEventListener("click", () => {
  document.getElementById("deleteAccountModalOverlay").classList.add("modal-hidden");
});

document.getElementById("confirmDeleteAccount").addEventListener("click", async () => {
  document.getElementById("deleteAccountModalOverlay").classList.add("modal-hidden");

  try {
    const res = await fetch("/deleteAccount", { method: "DELETE" });
    const data = await res.json(); // parse server response

    if (data.success) {
      // show success toast
      vanillaToast.success("Account deleted successfully.", { duration: 3000 });
      // redirect after short delay so toast can be seen
      setTimeout(() => window.location.href = "/login", 1500);
    } else {
      // show error toast
      vanillaToast.error(data.error || "Failed to delete account.", { duration: 3000 });
    }
  } catch (err) {
    console.error(err);
    vanillaToast.error("Failed to delete account. Please try again later.", { duration: 3000 });
  }
});
</script>


</body>

</html>